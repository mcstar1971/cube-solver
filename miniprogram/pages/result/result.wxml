<!-- pages/result/result.wxml -->
<view class="container">
  <view class="success-icon">✓</view>
  
  <text class="title">还原完成</text>
  
  <view class="stats">
    <view class="stat-item">
      <text class="stat-value">{{totalSteps}}</text>
      <text class="stat-label">步数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{timeUsed}}</text>
      <text class="stat-label">用时</text>
    </view>
  </view>

  <view class="actions">
    <button class="btn-primary" bindtap="scanAgain">再解一个</button>
    <button class="btn-secondary" bindtap="shareResult">分享成绩</button>
  </view>
</view>
