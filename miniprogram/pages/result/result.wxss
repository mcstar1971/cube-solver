/* pages/result/result.wxss */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #000;
  padding: 40rpx;
}

.success-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #fff;
  color: #000;
  font-size: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 80rpx;
}

.stats {
  display: flex;
  gap: 80rpx;
  margin-bottom: 80rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  max-width: 600rpx;
}

.btn-primary {
  background: #fff;
  color: #000;
  border: none;
  border-radius: 8rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-secondary {
  background: transparent;
  color: #888;
  border: 2rpx solid #333;
  border-radius: 8rpx;
  padding: 28rpx;
  font-size: 28rpx;
}
