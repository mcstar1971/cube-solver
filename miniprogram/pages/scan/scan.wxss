/* pages/scan/scan.wxss - 拍照模式 */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
}

/* 摄像头 */
.camera {
  width: 100%;
  height: 55vh;
  position: relative;
}

/* 扫描框 */
.scan-frame {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 500rpx;
  height: 500rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.scan-corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-color: #fff;
  border-style: solid;
  border-width: 0;
}

.scan-corner.tl {
  top: -4rpx;
  left: -4rpx;
  border-top-width: 6rpx;
  border-left-width: 6rpx;
}

.scan-corner.tr {
  top: -4rpx;
  right: -4rpx;
  border-top-width: 6rpx;
  border-right-width: 6rpx;
}

.scan-corner.bl {
  bottom: -4rpx;
  left: -4rpx;
  border-bottom-width: 6rpx;
  border-left-width: 6rpx;
}

.scan-corner.br {
  bottom: -4rpx;
  right: -4rpx;
  border-bottom-width: 6rpx;
  border-right-width: 6rpx;
}

/* 3x3网格 */
.grid-overlay {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  padding: 10rpx;
  box-sizing: border-box;
}

.grid-row {
  display: flex;
  justify-content: space-around;
}

.grid-cell {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 当前面提示 */
.current-face-hint {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
}

.hint-box {
  background: rgba(0, 0, 0, 0.7);
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
}

.hint-text {
  color: #fff;
  font-size: 28rpx;
}

/* 状态显示 */
.status-area {
  padding: 30rpx 40rpx 20rpx;
  text-align: center;
}

.status-text {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.hint-text {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
}

/* 已拍摄的面 */
.captured-area {
  padding: 20rpx 40rpx;
}

.captured-faces {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.captured-face {
  width: 90rpx;
  height: 110rpx;
  border: 4rpx solid #333;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  opacity: 0.5;
  transition: all 0.3s;
  background: #1a1a1a;
  overflow: hidden;
}

.captured-face.done {
  opacity: 1;
  border-color: #4CAF50;
}

.face-thumb {
  width: 100%;
  height: 70rpx;
  object-fit: cover;
}

.face-placeholder {
  width: 100%;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2a2a2a;
}

.face-icon {
  font-size: 36rpx;
}

.captured-label {
  font-size: 20rpx;
  color: #888;
  margin-top: 4rpx;
}

.check-mark {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 28rpx;
  height: 28rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #fff;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  margin-top: 16rpx;
}

/* 识别结果弹窗 */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 40rpx;
  width: 85%;
  max-width: 600rpx;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

.modal-hint {
  display: block;
  font-size: 28rpx;
  color: #888;
  text-align: center;
  margin-top: 12rpx;
}

/* 颜色预览 */
.color-preview {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.preview-row {
  display: flex;
  gap: 8rpx;
}

.preview-cell {
  width: 70rpx;
  height: 70rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #000;
}

.c-white { background: #FFFFFF; border: 2rpx solid #ccc; }
.c-yellow { background: #FFEB3B; }
.c-red { background: #F44336; color: #fff; }
.c-orange { background: #FF9800; }
.c-green { background: #4CAF50; }
.c-blue { background: #2196F3; color: #fff; }

.modal-tip {
  display: block;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-top: 20rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-retry {
  flex: 1;
  background: transparent;
  color: #888;
  border: 2rpx solid #444;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-confirm {
  flex: 1;
  background: #4CAF50;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 操作按钮 */
.action-area {
  padding: 30rpx 40rpx 50rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: auto;
}

.btn-capture {
  background: #fff;
  color: #000;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.capture-icon {
  font-size: 40rpx;
}

.btn-capture[disabled] {
  background: #333;
  color: #666;
}

.btn-secondary {
  background: transparent;
  color: #888;
  border: 2rpx solid #333;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 26rpx;
}

/* 隐藏的 canvas */
#photoCanvas {
  position: absolute;
  left: -9999rpx;
  width: 300px;
  height: 300px;
}
