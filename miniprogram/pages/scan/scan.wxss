/* pages/scan/scan.wxss - 拍照模式（调试版） */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
}

/* 摄像头 */
.camera {
  width: 100%;
  height: 50vh;
  position: relative;
}

/* 扫描框 */
.scan-frame {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 450rpx;
  height: 450rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.scan-corner {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  border-color: #fff;
  border-style: solid;
  border-width: 0;
}

.scan-corner.tl {
  top: -4rpx;
  left: -4rpx;
  border-top-width: 6rpx;
  border-left-width: 6rpx;
}

.scan-corner.tr {
  top: -4rpx;
  right: -4rpx;
  border-top-width: 6rpx;
  border-right-width: 6rpx;
}

.scan-corner.bl {
  bottom: -4rpx;
  left: -4rpx;
  border-bottom-width: 6rpx;
  border-left-width: 6rpx;
}

.scan-corner.br {
  bottom: -4rpx;
  right: -4rpx;
  border-bottom-width: 6rpx;
  border-right-width: 6rpx;
}

/* 3x3网格 */
.grid-overlay {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  padding: 8rpx;
  box-sizing: border-box;
}

.grid-row {
  display: flex;
  justify-content: space-around;
}

.grid-cell {
  width: 130rpx;
  height: 130rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 当前面提示 */
.current-face-hint {
  position: absolute;
  bottom: 30rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
}

.hint-box {
  background: rgba(0, 0, 0, 0.7);
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
}

.hint-text {
  color: #fff;
  font-size: 26rpx;
}

/* 状态显示 */
.status-area {
  padding: 24rpx 40rpx 16rpx;
  text-align: center;
}

.status-text {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.hint-text {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-top: 8rpx;
}

/* 已拍摄的面 */
.captured-area {
  padding: 16rpx 40rpx;
}

.captured-faces {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.captured-face {
  width: 80rpx;
  height: 100rpx;
  border: 4rpx solid #333;
  border-radius: 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  opacity: 0.5;
  transition: all 0.3s;
  background: #1a1a1a;
  overflow: hidden;
}

.captured-face.done {
  opacity: 1;
  border-color: #4CAF50;
}

.face-thumb {
  width: 100%;
  height: 60rpx;
  object-fit: cover;
}

.face-placeholder {
  width: 100%;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2a2a2a;
}

.face-icon {
  font-size: 32rpx;
}

.captured-label {
  font-size: 18rpx;
  color: #888;
  margin-top: 4rpx;
}

.check-mark {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 24rpx;
  height: 24rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: #fff;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #666;
  margin-top: 12rpx;
}

/* 识别结果弹窗 - 可滚动 */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-scroll {
  width: 90%;
  max-height: 85vh;
}

.modal-content {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 32rpx;
}

.modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

.modal-hint {
  display: block;
  font-size: 24rpx;
  color: #888;
  text-align: center;
  margin-top: 8rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  color: #aaa;
  margin-bottom: 12rpx;
}

/* 照片区域 */
.photo-section {
  margin-top: 24rpx;
}

.captured-photo {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  background: #2a2a2a;
}

/* 颜色区域 */
.color-section {
  margin-top: 24rpx;
}

.color-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  background: #2a2a2a;
  border-radius: 8rpx;
}

.preview-row {
  display: flex;
  gap: 8rpx;
}

.preview-cell {
  width: 60rpx;
  height: 60rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #000;
}

/* 颜色类 */
.c-U { background: #FFFFFF; border: 2rpx solid #ccc; }
.c-D { background: #FFEB3B; }
.c-F { background: #F44336; color: #fff; }
.c-B { background: #FF9800; }
.c-L { background: #4CAF50; }
.c-R { background: #2196F3; color: #fff; }

/* 调试信息：每个格子 */
.debug-section {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #2a2a2a;
  border-radius: 8rpx;
}

.debug-grid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.debug-row {
  display: flex;
  gap: 8rpx;
  justify-content: center;
}

.debug-cell {
  width: 180rpx;
  padding: 8rpx;
  background: #1a1a1a;
  border-radius: 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.debug-color {
  width: 40rpx;
  height: 40rpx;
  border-radius: 4rpx;
  border: 1rpx solid #444;
}

.debug-text {
  font-size: 16rpx;
  color: #666;
  font-family: monospace;
}

.debug-result {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.modal-tip {
  display: block;
  font-size: 22rpx;
  color: #666;
  text-align: center;
  margin-top: 20rpx;
}

.modal-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-retry {
  flex: 1;
  background: transparent;
  color: #888;
  border: 2rpx solid #444;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 26rpx;
}

.btn-confirm {
  flex: 1;
  background: #4CAF50;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

/* 操作按钮 */
.action-area {
  padding: 24rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: auto;
}

.btn-capture {
  background: #fff;
  color: #000;
  border: none;
  border-radius: 10rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.capture-icon {
  font-size: 36rpx;
}

.btn-capture[disabled] {
  background: #333;
  color: #666;
}

.btn-capture.btn-start {
  background: #4CAF50;
  color: #fff;
}

.btn-secondary {
  background: transparent;
  color: #888;
  border: 2rpx solid #333;
  border-radius: 8rpx;
  padding: 18rpx;
  font-size: 24rpx;
}

/* 隐藏的 canvas - 必须在可视区域内才能工作 */
.hidden-canvas {
  position: absolute;
  left: -9999rpx;
  top: 0;
  width: 400px;
  height: 400px;
  visibility: hidden;
}
