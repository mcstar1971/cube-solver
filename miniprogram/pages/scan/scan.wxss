/* pages/scan/scan.wxss */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
}

/* 摄像头 */
.camera {
  width: 100%;
  height: 60vh;
  position: relative;
}

/* 扫描框 */
.scan-frame {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 500rpx;
  height: 500rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.scan-corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-color: #fff;
  border-style: solid;
  border-width: 0;
}

.scan-corner.tl {
  top: -4rpx;
  left: -4rpx;
  border-top-width: 6rpx;
  border-left-width: 6rpx;
}

.scan-corner.tr {
  top: -4rpx;
  right: -4rpx;
  border-top-width: 6rpx;
  border-right-width: 6rpx;
}

.scan-corner.bl {
  bottom: -4rpx;
  left: -4rpx;
  border-bottom-width: 6rpx;
  border-left-width: 6rpx;
}

.scan-corner.br {
  bottom: -4rpx;
  right: -4rpx;
  border-bottom-width: 6rpx;
  border-right-width: 6rpx;
}

/* 3x3网格 */
.grid-overlay {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  padding: 10rpx;
  box-sizing: border-box;
}

.grid-row {
  display: flex;
  justify-content: space-around;
}

.grid-cell {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 状态显示 */
.status-area {
  padding: 40rpx;
  text-align: center;
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.hint-text {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-top: 16rpx;
}

/* 进度指示 */
.progress-area {
  padding: 0 40rpx;
}

.cube-faces {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.face {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #333;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #000;
  transition: all 0.3s;
  opacity: 0.4;
}

/* 各面颜色 */
.face-white { background: #FFFFFF; }
.face-yellow { background: #FFFF00; }
.face-red { background: #FF0000; color: #fff; }
.face-orange { background: #FFA500; }
.face-green { background: #00FF00; }
.face-blue { background: #0000FF; color: #fff; }

/* 已扫描状态 */
.face.scanned {
  opacity: 1;
  border-color: #fff;
  box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.5);
}

.face-label {
  font-weight: 600;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮 */
.action-area {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: auto;
}

.btn-scan {
  background: #fff;
  color: #000;
  border: none;
  border-radius: 8rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-scan[disabled] {
  background: #333;
  color: #666;
}

.btn-secondary {
  background: transparent;
  color: #888;
  border: 2rpx solid #333;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
}
