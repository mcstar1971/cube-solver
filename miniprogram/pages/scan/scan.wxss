/* pages/scan/scan.wxss */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
}

/* 摄像头 */
.camera {
  width: 100%;
  height: 60vh;
  position: relative;
}

/* 扫描框 */
.scan-frame {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 500rpx;
  height: 500rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.scan-corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-color: #fff;
  border-style: solid;
  border-width: 0;
}

.scan-corner.tl {
  top: -4rpx;
  left: -4rpx;
  border-top-width: 6rpx;
  border-left-width: 6rpx;
}

.scan-corner.tr {
  top: -4rpx;
  right: -4rpx;
  border-top-width: 6rpx;
  border-right-width: 6rpx;
}

.scan-corner.bl {
  bottom: -4rpx;
  left: -4rpx;
  border-bottom-width: 6rpx;
  border-left-width: 6rpx;
}

.scan-corner.br {
  bottom: -4rpx;
  right: -4rpx;
  border-bottom-width: 6rpx;
  border-right-width: 6rpx;
}

/* 状态显示 */
.status-area {
  padding: 40rpx;
  text-align: center;
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.hint-text {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-top: 16rpx;
}

/* 进度指示 */
.progress-area {
  padding: 0 40rpx;
}

.cube-faces {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.face {
  width: 60rpx;
  height: 60rpx;
  border: 2rpx solid #444;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s;
}

.face.scanned {
  background: #fff;
  color: #000;
  border-color: #fff;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮 */
.action-area {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: auto;
}

.btn-scan {
  background: #fff;
  color: #000;
  border: none;
  border-radius: 8rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-scan[disabled] {
  background: #333;
  color: #666;
}

.btn-secondary {
  background: transparent;
  color: #888;
  border: 2rpx solid #333;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
}
