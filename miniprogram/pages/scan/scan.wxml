<!-- pages/scan/scan.wxml -->
<view class="container">
  <!-- 摄像头区域 -->
  <camera 
    class="camera" 
    device-position="back" 
    flash="off"
    binderror="onCameraError">
    <!-- 扫描框 -->
    <cover-view class="scan-frame">
      <cover-view class="scan-corner tl"></cover-view>
      <cover-view class="scan-corner tr"></cover-view>
      <cover-view class="scan-corner bl"></cover-view>
      <cover-view class="scan-corner br"></cover-view>
      <!-- 3x3网格指示 -->
      <cover-view class="grid-overlay">
        <cover-view class="grid-row" wx:for="{{[0,1,2]}}" wx:key="*this">
          <cover-view class="grid-cell" wx:for="{{[0,1,2]}}" wx:key="*this"></cover-view>
        </cover-view>
      </cover-view>
    </cover-view>
  </camera>

  <!-- 状态显示 -->
  <view class="status-area">
    <text class="status-text">{{statusText}}</text>
    <text class="hint-text">{{hintText}}</text>
    <text class="debug-text" wx:if="{{debugInfo}}">{{debugInfo}}</text>
  </view>

  <!-- 进度指示 - 用颜色表示 -->
  <view class="progress-area">
    <view class="cube-faces">
      <view class="face face-white {{scanned.U ? 'scanned' : ''}}" bindtap="toggleFace" data-face="U">
        <text class="face-label">白</text>
      </view>
      <view class="face face-yellow {{scanned.D ? 'scanned' : ''}}" bindtap="toggleFace" data-face="D">
        <text class="face-label">黄</text>
      </view>
      <view class="face face-red {{scanned.F ? 'scanned' : ''}}" bindtap="toggleFace" data-face="F">
        <text class="face-label">红</text>
      </view>
      <view class="face face-orange {{scanned.B ? 'scanned' : ''}}" bindtap="toggleFace" data-face="B">
        <text class="face-label">橙</text>
      </view>
      <view class="face face-green {{scanned.L ? 'scanned' : ''}}" bindtap="toggleFace" data-face="L">
        <text class="face-label">绿</text>
      </view>
      <view class="face face-blue {{scanned.R ? 'scanned' : ''}}" bindtap="toggleFace" data-face="R">
        <text class="face-label">蓝</text>
      </view>
    </view>
    <text class="progress-text">已扫描 {{scannedCount}}/6 面（点击可手动标记）</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-area">
    <button class="btn-scan" bindtap="startScan" disabled="{{isScanning}}">
      {{scannedCount >= 6 ? '开始还原' : (isScanning ? '扫描中...' : '开始扫描')}}
    </button>
    <button class="btn-secondary" bindtap="resetScan">重置</button>
  </view>
</view>
