<!-- pages/scan/scan.wxml - 拍照模式 -->
<view class="container">
  <!-- 隐藏的 canvas 用于图片处理 -->
  <canvas type="2d" id="photoCanvas" canvas-id="photoCanvas"></canvas>
  <!-- 摄像头区域 -->
  <camera 
    class="camera" 
    device-position="back" 
    flash="auto"
    binderror="onCameraError">
    <!-- 扫描框 -->
    <cover-view class="scan-frame">
      <cover-view class="scan-corner tl"></cover-view>
      <cover-view class="scan-corner tr"></cover-view>
      <cover-view class="scan-corner bl"></cover-view>
      <cover-view class="scan-corner br"></cover-view>
      <!-- 3x3网格指示 -->
      <cover-view class="grid-overlay">
        <cover-view class="grid-row" wx:for="{{[0,1,2]}}" wx:key="*this">
          <cover-view class="grid-cell" wx:for="{{[0,1,2]}}" wx:key="*this"></cover-view>
        </cover-view>
      </cover-view>
    </cover-view>
    <!-- 当前要拍的面 -->
    <cover-view class="current-face-hint">
      <cover-view class="hint-box">
        <cover-view class="hint-text">请对准{{currentFaceName}}</cover-view>
      </cover-view>
    </cover-view>
  </camera>

  <!-- 状态显示 -->
  <view class="status-area">
    <text class="status-text">{{statusText}}</text>
    <text class="hint-text">{{hintText}}</text>
  </view>

  <!-- 已拍摄的面 - 缩略图 -->
  <view class="captured-area">
    <view class="captured-faces">
      <block wx:for="{{faceOrder}}" wx:key="*this">
        <view class="captured-face {{captured[item] ? 'done' : ''}}" bindtap="onFaceTap" data-face="{{item}}">
          <image wx:if="{{facePhotos[item]}}" class="face-thumb" src="{{facePhotos[item]}}" mode="aspectFill"></image>
          <view wx:else class="face-placeholder">
            <text class="face-icon">{{faceIcons[item]}}</text>
          </view>
          <text class="captured-label">{{faceShortNames[item]}}</text>
          <view wx:if="{{captured[item]}}" class="check-mark">✓</view>
        </view>
      </block>
    </view>
    <text class="progress-text">{{capturedCount}}/6 面</text>
  </view>

  <!-- 识别结果弹窗 - 调试版 -->
  <view class="result-modal" wx:if="{{showResultModal}}">
    <scroll-view scroll-y class="modal-scroll">
      <view class="modal-content">
        <text class="modal-title">识别结果</text>
        <text class="modal-hint">{{currentFaceName}}</text>
        
        <!-- 拍摄的照片 -->
        <view class="photo-section">
          <text class="section-label">📷 拍摄照片</text>
          <image class="captured-photo" src="{{currentPhotoPath}}" mode="aspectFit"></image>
        </view>
        
        <!-- 识别的颜色 -->
        <view class="color-section">
          <text class="section-label">🎨 识别颜色</text>
          <view class="color-preview">
            <view class="preview-row" wx:for="{{detectedColors}}" wx:key="index">
              <view class="preview-cell c-{{item}}" 
                    wx:for="{{item}}" wx:key="*this" wx:for-item="color">
                <text>{{colorLabels[color]}}</text>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 调试信息：每个格子的RGB/HSV -->
        <view class="debug-section">
          <text class="section-label">🔧 每格详细数据</text>
          <view class="debug-grid">
            <view class="debug-row" wx:for="{{cellDebugInfo}}" wx:key="index" wx:for-index="rowIdx">
              <view class="debug-cell" wx:for="{{item}}" wx:key="*this" wx:for-item="cell">
                <view class="debug-color c-{{cell.detected}}"></view>
                <text class="debug-text">R{{cell.rgb[0]}} G{{cell.rgb[1]}} B{{cell.rgb[2]}}</text>
                <text class="debug-text">H{{cell.hsv.h}} S{{cell.hsv.s}} V{{cell.hsv.v}}</text>
                <text class="debug-result">→{{colorLabels[cell.detected]}}</text>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 提示 -->
        <text class="modal-tip">请对比照片和识别结果是否一致</text>
        
        <!-- 操作按钮 -->
        <view class="modal-buttons">
          <button class="btn-retry" bindtap="retryPhoto">重拍</button>
          <button class="btn-confirm" bindtap="confirmPhoto">确认</button>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-area">
    <button class="btn-capture" bindtap="takePhoto" disabled="{{isProcessing || showResultModal}}">
      <text class="capture-icon">📷</text>
      <text>拍照</text>
    </button>
    <button class="btn-secondary" bindtap="resetScan">重置</button>
  </view>
</view>
