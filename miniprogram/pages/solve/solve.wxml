<!-- pages/solve/solve.wxml -->
<view class="container">
  <!-- 魔方展开图 -->
  <view class="cube-display">
    <view class="unfold-cube">
      <!-- 顶面 U -->
      <view class="cube-row top-offset">
        <view class="face-grid face-U">
          <view class="grid-row" wx:for="{{cubeState.U}}" wx:key="index">
            <view class="grid-cell c-{{item}}" wx:for="{{item}}" wx:key="*this" wx:for-item="color"></view>
          </view>
        </view>
      </view>
      
      <!-- 左面L 前面F 右面R 后面B -->
      <view class="cube-row middle-row">
        <view class="face-grid face-L">
          <view class="grid-row" wx:for="{{cubeState.L}}" wx:key="index">
            <view class="grid-cell c-{{item}}" wx:for="{{item}}" wx:key="*this" wx:for-item="color"></view>
          </view>
        </view>
        <view class="face-grid face-F">
          <view class="grid-row" wx:for="{{cubeState.F}}" wx:key="index">
            <view class="grid-cell c-{{item}}" wx:for="{{item}}" wx:key="*this" wx:for-item="color"></view>
          </view>
        </view>
        <view class="face-grid face-R">
          <view class="grid-row" wx:for="{{cubeState.R}}" wx:key="index">
            <view class="grid-cell c-{{item}}" wx:for="{{item}}" wx:key="*this" wx:for-item="color"></view>
          </view>
        </view>
        <view class="face-grid face-B">
          <view class="grid-row" wx:for="{{cubeState.B}}" wx:key="index">
            <view class="grid-cell c-{{item}}" wx:for="{{item}}" wx:key="*this" wx:for-item="color"></view>
          </view>
        </view>
      </view>
      
      <!-- 底面 D -->
      <view class="cube-row bottom-offset">
        <view class="face-grid face-D">
          <view class="grid-row" wx:for="{{cubeState.D}}" wx:key="index">
            <view class="grid-cell c-{{item}}" wx:for="{{item}}" wx:key="*this" wx:for-item="color"></view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 面标签 -->
    <view class="face-labels">
      <text class="label">U=白 D=黄 F=红 B=橙 L=绿 R=蓝</text>
    </view>
  </view>

  <!-- 步骤区域 -->
  <view class="step-area">
    <text class="step-number">步骤 {{currentStep}} / {{totalSteps}}</text>
    <view class="move-display">
      <text class="move-text">{{currentMove}}</text>
      <text class="move-hint">{{moveHint}}</text>
    </view>
    
    <!-- 面和方向说明 -->
    <view class="direction-guide">
      <text class="dir-title">{{moveGuide.faceName}}({{moveGuide.faceColor}})</text>
      <text class="dir-desc">{{moveGuide.directionDesc}}</text>
      <view class="dir-visual">
        <text class="dir-arrow">{{moveGuide.arrow}}</text>
      </view>
    </view>
    
    <text class="guide-text">{{guideText}}</text>
    
    <!-- 常见问题提示 -->
    <view class="tips">
      <text class="tips-title">💡 提示：</text>
      <text class="tips-text">顺时针/逆时针是从正对该面的角度看</text>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="control-area">
    <button class="btn-prev" bindtap="prevStep" disabled="{{currentStep <= 1}}">
      ← 上一步
    </button>
    <button class="btn-next" bindtap="nextStep">
      {{currentStep >= totalSteps ? '完成 ✓' : '下一步 →'}}
    </button>
  </view>

  <!-- 底部进度条 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>
</view>
