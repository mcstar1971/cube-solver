/* pages/solve/solve.wxss */

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #1a1a1a;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 魔方展开图 */
.cube-display {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.unfold-cube {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cube-row {
  display: flex;
  justify-content: center;
}

.top-offset {
  margin-bottom: 4rpx;
}

.middle-row {
  display: flex;
  gap: 4rpx;
}

.bottom-offset {
  margin-top: 4rpx;
}

/* 每个面 */
.face-grid {
  display: flex;
  flex-direction: column;
  border: 2rpx solid #333;
}

.grid-row {
  display: flex;
}

.grid-cell {
  width: 50rpx;
  height: 50rpx;
  border: 1rpx solid #333;
}

/* 颜色 */
.c-U { background: #FFFFFF; }
.c-D { background: #FFEB3B; }
.c-F { background: #F44336; }
.c-B { background: #FF9800; }
.c-L { background: #4CAF50; }
.c-R { background: #2196F3; }

/* 面标签 */
.face-labels {
  margin-top: 20rpx;
}

.face-labels .label {
  font-size: 22rpx;
  color: #666;
}

/* 步骤区域 */
.step-area {
  background: #2a2a2a;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  text-align: center;
}

.step-number {
  display: block;
  font-size: 28rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.move-display {
  margin-bottom: 16rpx;
}

.move-text {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
}

.move-hint {
  display: block;
  font-size: 32rpx;
  color: #4CAF50;
  margin-top: 8rpx;
}

.guide-text {
  display: block;
  font-size: 26rpx;
  color: #aaa;
  margin-top: 12rpx;
}

/* 方向指南 */
.direction-guide {
  background: #333;
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 16rpx 0;
}

.dir-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
}

.dir-desc {
  display: block;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.dir-visual {
  margin-top: 12rpx;
  text-align: center;
}

.dir-arrow {
  font-size: 48rpx;
}

/* 提示 */
.tips {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8rpx;
}

.tips-title {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 4rpx;
}

.tips-text {
  display: block;
  font-size: 20rpx;
  color: #666;
}

/* 控制按钮 */
.control-area {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}

.btn-prev, .btn-next {
  flex: 1;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.btn-prev {
  background: #333;
  color: #888;
}

.btn-next {
  background: #4CAF50;
  color: #fff;
}

.btn-prev[disabled] {
  background: #222;
  color: #444;
}

/* 进度条 */
.progress-bar {
  height: 6rpx;
  background: #333;
  border-radius: 3rpx;
  margin-top: auto;
}

.progress-fill {
  height: 100%;
  background: #4CAF50;
  border-radius: 3rpx;
  transition: width 0.3s;
}
